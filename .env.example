# Optional: if set, requires `Authorization: Bearer <DAEMON_API_KEY>`
DAEMON_API_KEY=

# Upstream provider selector
# - openrouter: uses OPENROUTER_* settings
# - opencode_zen: uses OPENCODE_* settings (https://opencode.ai/docs/zen/)
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LITELLM_MODEL=openrouter/anthropic/claude-opus-4.5

# OpenCode Zen (OpenAI-compatible endpoint)
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=opencode/claude-opus-4-5

# Dev-only: stream a canned response; no provider key required.
MOCK_LLM=false

# Runtime
ENV=dev
LOG_LEVEL=INFO
REQUEST_TIMEOUT_S=90
STREAM_PING_INTERVAL_S=15
