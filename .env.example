# Optional: if set, requires `Authorization: Bearer <DAEMON_API_KEY>`
DAEMON_API_KEY=

# Default provider for LLM calls
# Options: venice, openrouter, opencode_zen, or custom provider name
DEFAULT_PROVIDER=venice

# Request and stream settings
REQUEST_TIMEOUT_S=90
STREAM_PING_INTERVAL_S=15

# Development: stream canned responses without calling any provider
MOCK_LLM=false

# Runtime
ENV=dev
LOG_LEVEL=INFO

# ================================================
# Venice AI (Default - OpenAI-compatible, privacy-focused)
# https://api.venice.ai/api/v1
# Get free API key: https://venice.ai/settings/api
# Note: "Anonymous" means no conversation history stored by Venice,
#       not keyless API access. API key is required.
# ================================================
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=venice-uncensored

# Tier-1 Recommended Models for Primary Daemon Orchestration
# Comma-separated list of model IDs (without veniceai/ prefix)
# These models appear first in /v1/models and are marked as "recommended"
# Benchmark tier: claude-opus-45, kimi-k2-5, kimi-k2-thinking
TIER1_MODELS=claude-opus-45,kimi-k2-5,kimi-k2-thinking

# ================================================
# OpenRouter (Multi-provider gateway)
# https://openrouter.ai/docs
# ================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LITELLM_MODEL=openrouter/anthropic/claude-opus-4.5

# ================================================
# OpenCode Zen (OpenAI-compatible endpoint)
# https://opencode.ai/docs/zen/
# ================================================
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=opencode/claude-opus-4-5

# ================================================
# Custom Provider Configuration
# Add any provider by setting PROVIDER_{NAME}_* variables
# Example for a custom OpenAI-compatible provider:
# ================================================
# PROVIDER_CUSTOM_BASE_URL=https://api.custom-ai.com/v1
# PROVIDER_CUSTOM_API_KEY=your-api-key-here
# PROVIDER_CUSTOM_MODEL=custom-model-name
# PROVIDER_CUSTOM_REQUIRES_AUTH=true
